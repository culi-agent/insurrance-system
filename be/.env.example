# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insurance_system
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (REQUIRED - app will NOT start without these)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# OTP
OTP_EXPIRES_IN=300
OTP_LENGTH=6

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=30


# ========== Email Provider ==========
# Provider: sendgrid | ses | mailgun | mock (default: mock for dev)
EMAIL_PROVIDER=mock
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@insurance-system.vn
EMAIL_FROM_NAME=Insurance System
EMAIL_REPLY_TO=support@insurance-system.vn

# Email templates (SendGrid dynamic template IDs)
EMAIL_TEMPLATE_OTP=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_TEMPLATE_RESET=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_TEMPLATE_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_TEMPLATE_LOCKED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== SMS Provider ==========
# Provider: twilio | aws-sns | mock (default: mock for dev)
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+84xxxxxxxxxx

# ========== Notification Retry ==========
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_INITIAL_DELAY=1000
NOTIFICATION_MAX_DELAY=30000
NOTIFICATION_BACKOFF_MULTIPLIER=2

# CORS
CORS_ORIGIN=http://localhost:5173

# Cookie
COOKIE_DOMAIN=localhost
