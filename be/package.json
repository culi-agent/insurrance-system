{
  "name": "insurance-system-backend",
  "version": "1.0.0",
  "description": "Backend API for Insurance System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:ci": "jest --config jest.config.ts --ci --coverage --reporters=default --reporters=jest-junit",
    "loadtest": "k6 run loadtest/scenarios/main.js",
    "loadtest:auth": "k6 run loadtest/scenarios/auth-flow.js",
    "loadtest:products": "k6 run loadtest/scenarios/products.js",
    "loadtest:db": "k6 run loadtest/scenarios/database-stress.js",
    "loadtest:smoke": "k6 run -e LOAD_PROFILE=smoke loadtest/scenarios/main.js",
    "loadtest:stress": "k6 run -e LOAD_PROFILE=stress loadtest/scenarios/main.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/database.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/database.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/database.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17",
    "reflect-metadata": "^0.1.14",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "uuid": "^9.0.0",
    "express-rate-limit": "^7.1.4",
    "cookie-parser": "^1.4.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.1.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.7",
    "@types/cookie-parser": "^1.4.6",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "supertest": "^6.3.3"
  }
}
